{{- $git_email := promptStringOnce . "git_email" "Git email" -}}
{{- $git_name := promptStringOnce . "git_name" "Git name" -}}
{{- $git_signingkey := promptStringOnce . "git_signingkey" "GPG signing key (Git)" -}}
{{- $recipient_encrypt := promptStringOnce . "recipient_encrypt" "Recipient (encryption)" -}}
{{- $personal := promptBoolOnce . "personal" "Personal setup?" -}}
{{- $setup := promptStringOnce . "setup" "type of setup (personal or work)" -}}

{{- $repos_ws := "" -}}
{{- if and (eq .chezmoi.os "linux") -}}
{{- $repos_ws := promptStringOnce . "repos_ws" "Directory for external content (repos, etc.)" -}}
{{- end -}}

{{- $gpgtool := "" -}}
{{- if eq .chezmoi.os "windows" -}}
{{-   $gpgtool = "C:/Program Files/GnuPG/bin/gpg.exe" -}}
{{- else -}}
{{-   $gpgtool := promptStringOnce . "gpgtool" "gpg path" -}}
{{- end -}}

---
data:
  git_email: {{ $git_email | quote }}
  git_name: {{ $git_name | quote }}
  setup: {{ $setup | quote }}
  personal: {{ $personal }}
  git_signingkey: {{ $git_signingkey | quote }}
  gpgtool: {{ $gpgtool | quote }}
  recipient_encrypt: {{ $recipient_encrypt | quote }}
{{- if eq .chezmoi.os "linux" }}
  repos_ws: {{ $repos_ws | quote }}
{{- end }}

encryption: gpg
gpg:
  recipient: {{ $recipient_encrypt | quote }}
  args: "--quiet"
